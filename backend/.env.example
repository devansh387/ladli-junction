# ══════════════════════════════════════════════════════════════════════════════
# Ladli Junction Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000

# Database (Supabase PostgreSQL — use connection pooler URL, port 6543)
DATABASE_URL=postgresql://postgres.XXXXX:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token Expiry
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7

# CORS — Frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Brevo Email API (https://brevo.com — free 300 emails/day)
BREVO_API_KEY=
MAIL_FROM=your-verified-email@gmail.com
MAIL_FROM_NAME=Ladli Junction
ORDER_NOTIFICATION_EMAIL=your-email@gmail.com

# Admin Credentials (seeded into DB on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=ChangeThisToAStrongPassword!

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# Supabase Storage (for file uploads — free 1GB)
# Get from: Supabase Dashboard → Settings → API → URL and service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
